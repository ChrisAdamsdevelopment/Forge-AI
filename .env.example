# Forge-AI Environment Configuration
# Copy this file to .env and fill in your values

# ngrok configuration (optional — for remote MCP access)
NGROK_DOMAIN=your-domain.ngrok-free.dev
NGROK_TUNNEL_ID=rd_...

# Server ports (defaults shown)
FASTAPI_PORT=9147
FAST_MCP_PORT=8000
DASHBOARD_PORT=7999
PENTEST_MCP_PORT=8001
ROUTER_MCP_PORT=8002

# Filesystem allowed roots (colon-separated paths)
# Leave empty to default to your home directory
FORGE_ALLOWED_ROOTS=

# Persistent memory database
# Leave empty to default to ~/.forge/memory.db
FORGE_MEMORY_DB=

# Router connection (optional)
ROUTER_HOST=192.168.1.1
ROUTER_PORT=80
ROUTER_USERNAME=root
ROUTER_PASSWORD=your-router-password

# Pentest configuration
PENTEST_MAX_SESSIONS=10
PENTEST_DEFAULT_TIMEOUT=30
PENTEST_WSL_DISTRO=Ubuntu

# Operator mode (set to true for autonomous operation without confirmations)
FORGE_OPERATOR_AUTO_APPROVE=false
