{
  "mcp_ai_agent": {
    "description": "Least-privilege MCP automation agent access",
    "read": {
      "uci": [
        "get",
        "sections"
      ],
      "network": [
        "interface"
      ],
      "network.interface": [
        "status"
      ],
      "network.device": [
        "status"
      ],
      "system": [
        "info",
        "board",
        "logs"
      ],
      "iwinfo": [
        "scan"
      ],
      "luci.network.firewall": [
        "get_rules"
      ],
      "opkg": [
        "list",
        "search"
      ],
      "service": [
        "list"
      ]
    },
    "write": {
      "uci": [
        "set",
        "commit",
        "revert",
        "changes"
      ],
      "network.interface": [
        "restart"
      ],
      "luci.network.firewall": [
        "add_rule",
        "delete_rule"
      ],
      "service": [
        "reload"
      ],
      "opkg": [
        "install"
      ]
    },
    "uci": {
      "access": "read_write",
      "whitelist": {
        "network": [
          "interface.*.ipaddr",
          "interface.*.netmask",
          "interface.*.proto",
          "interface.*.type",
          "route.*.target",
          "route.*.gateway"
        ],
        "wireless": [
          "device.*.hwmode",
          "device.*.channel",
          "interface.*.ssid",
          "interface.*.key",
          "interface.*.encryption"
        ],
        "firewall": [
          "rule.*",
          "zone.*.name",
          "zone.*.input",
          "zone.*.output",
          "zone.*.forward"
        ],
        "dhcp": [
          "dnsmasq.*.enabled",
          "dnsmasq.*.rebind_protection",
          "host.*"
        ]
      },
      "deny": {
        "system": [
          "*"
        ],
        "admin": [
          "*"
        ]
      }
    },
    "filesystem": {
      "access": "read_only",
      "whitelist": [
        "/mnt/usb/*"
      ],
      "deny": [
        "/etc",
        "/root",
        "/sys",
        "/proc",
        "/dev",
        "/boot",
        "/lib"
      ]
    },
    "limits": {
      "timeout": 30,
      "concurrent_sessions": 10,
      "rate_limit": 100
    }
  }
}
