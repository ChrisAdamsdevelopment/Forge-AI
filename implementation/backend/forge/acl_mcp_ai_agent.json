{
  "mcp_ai_agent": {
    "description": "Least-privilege ACL for the Forge router MCP agent. Deploy to /usr/share/rpcd/acl.d/ on the OpenWrt device and create a matching rpcd user (uci set rpcd.@login[?]=login; ...).",
    "read": {
      "ubus": {
        "session": ["access"],
        "system": ["info", "board"],
        "log": ["read"],
        "network.interface": ["dump", "status"],
        "network.device": ["status"],
        "iwinfo": ["devices", "info", "scan", "assoclist"],
        "uci": ["get", "changes"],
        "opkg": ["list_installed", "find"],
        "service": ["list"],
        "file": ["stat"]
      },
      "uci": ["network", "wireless", "firewall", "dhcp", "system"]
    },
    "write": {
      "ubus": {
        "uci": ["set", "add", "delete", "commit", "revert"],
        "network.interface": ["up", "down"],
        "service": ["event"],
        "opkg": ["install"],
        "file": ["exec"]
      },
      "uci": ["network", "wireless", "firewall", "dhcp"],
      "file": {
        "/bin/ping": ["exec"]
      }
    }
  }
}
