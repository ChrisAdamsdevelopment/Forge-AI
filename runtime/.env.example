# Forge environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
FORGE_HOST=127.0.0.1
FORGE_PORT=9147
FORGE_RELOAD=false
FORGE_LOG_LEVEL=info

# ── Inference ─────────────────────────────────────────────────────────────────
FORGE_OLLAMA_BASE_URL=http://127.0.0.1:11434
FORGE_DEFAULT_MODEL=qwen3.5
FORGE_EMBED_MODEL=bge-m3
FORGE_NUM_CTX=32768
FORGE_TEMPERATURE=0.2

# Remote GPU (optional) — leave blank to use local Ollama only
FORGE_REMOTE_INFERENCE_URL=
FORGE_REMOTE_INFERENCE_KEY=
FORGE_REMOTE_MODEL=

# ── Paths ─────────────────────────────────────────────────────────────────────
FORGE_DATA_DIR=~/.forge
FORGE_MODULES_DIR=modules
FORGE_RAG_DIR=rag-kb

# ── RAG ───────────────────────────────────────────────────────────────────────
FORGE_CHUNK_SIZE=512
FORGE_CHUNK_OVERLAP=64
FORGE_RAG_TOP_K=20
FORGE_RAG_RERANK_TOP_N=5

# ── Features ──────────────────────────────────────────────────────────────────
FORGE_ENABLE_LAN=false
FORGE_ENABLE_TRAINING=false
FORGE_ENABLE_EVAL=true
FORGE_ENABLE_MODULES=true
